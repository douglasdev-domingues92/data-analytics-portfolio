# =============================
# Dados (NÃO versionar - regra geral)
# =============================

# Ignora todos os .csv por padrão (para evitar subir dados reais)
*.csv

# MAS não ignore os dados simulados do projeto:
!data/raw/*.csv
!data/processed/*.csv

# Outros formatos de dados que não queremos versionar
*.xlsx
*.xls
*.parquet
*.json
*.zip
*.gz

